{
    "buildCommand": "pip install -r requirements.txt && python preload_model.py",
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/health",
            "dest": "api/index.py"
        },
        {
            "src": "/remove-bg",
            "dest": "api/index.py",
            "methods": [
                "POST"
            ]
        },
        {
            "src": "/(.*)",
            "dest": "api/index.py"
        }
    ]
}